# ============================================================
# Vinmec AI Agent — Environment template
# Copy thành .env rồi sửa giá trị thật. KHÔNG commit .env.
# ============================================================

# ─── Database ────────────────────────────────────────────────
# Tự động chấp nhận nếu dùng docker-compose (service `db` nội bộ).
DATABASE_URL=postgresql://postgres:postgres@db:5432/vinmec_ai?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vinmec_ai

# ─── LLM ─────────────────────────────────────────────────────
# BẮT BUỘC: lấy từ https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Security (Lab 12) ───────────────────────────────────────
# Sinh random: `openssl rand -hex 32`
AGENT_API_KEY=dev-key-change-me-in-production
# Key đơn giản cho trang /admin/feedback
ADMIN_KEY=vinmec-demo-2026
# REQUIRE_AUTH=false để bỏ qua X-API-Key check (chỉ dev local)
REQUIRE_AUTH=true

# ─── Rate limit & Cost guard (Lab 12) ────────────────────────
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=0.5

# ─── Next.js ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_APP_NAME=Trợ lý ảo VinmecCare
APP_VERSION=1.0.0

# ─── Cloudflare Tunnel (chỉ cần cho production VPS) ──────────
# Bỏ trống nếu chạy local — docker-compose profile "tunnel" không activate.
CLOUDFLARE_TUNNEL_TOKEN=
